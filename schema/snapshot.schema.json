{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aquifer-labs.github.io/ocf/schema/snapshot.schema.json",
  "title": "OCF Working Snapshot",
  "type": "object",
  "required": ["budget_tokens", "token_count", "entries"],
  "properties": {
    "budget_tokens": { "type": "integer", "minimum": 1 },
    "token_count": { "type": "integer", "minimum": 0 },
    "saturation": { "type": "number", "minimum": 0 },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "slot", "content", "tokens", "score", "committed_at"],
        "properties": {
          "id": { "type": "string" },
          "slot": { "type": "string" },
          "namespace": {
            "type": "string",
            "minLength": 1,
            "description": "Project/partition key. Omitted entries inherit manifest.default_namespace, or shared when the manifest has none."
          },
          "version": {
            "type": "integer",
            "minimum": 1,
            "default": 1,
            "description": "Monotonic per-record version used for optimistic-lock conflict detection."
          },
          "author_id": {
            "type": "string",
            "minLength": 1,
            "description": "Writer identity for provenance; distinct from routing, session, or namespace keys."
          },
          "access_list": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true,
            "default": [],
            "description": "Additional namespace/user principals allowed to read this entry; namespace and shared visibility still apply."
          },
          "content": { "type": "string" },
          "tokens": { "type": "integer", "minimum": 0 },
          "score": { "type": "number" },
          "resolution": { "type": "string", "enum": ["full", "compressed", "pointer"] },
          "unit_ref": { "type": "string" },
          "committed_at": { "type": "string", "format": "date-time" },
          "last_access": { "type": "string", "format": "date-time" },
          "access_count": { "type": "integer", "minimum": 0 },
          "retrieval_strength": { "type": "number", "minimum": 0 },
          "state": { "type": "string", "enum": ["active", "archived"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
