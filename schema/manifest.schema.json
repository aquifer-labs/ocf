{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aquifer-labs.github.io/ocf/schema/manifest.schema.json",
  "title": "OCF Manifest",
  "type": "object",
  "required": ["ocf_version", "created", "unit_source"],
  "properties": {
    "ocf_version": { "type": "string" },
    "agent_id": { "type": "string" },
    "created": { "type": "string", "format": "date-time" },
    "unit_source": {
      "type": "string",
      "description": "inline | pam | amp | oamp | artesian | files | ..."
    },
    "unit_refs": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
