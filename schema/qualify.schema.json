{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aquifer-labs.github.io/ocf/schema/qualify.schema.json",
  "title": "OCF Qualify Log entry (one JSON object per line of qualify.jsonl)",
  "type": "object",
  "required": ["ts", "unit_ref", "admitted", "score"],
  "properties": {
    "ts": { "type": "string", "format": "date-time" },
    "unit_ref": { "type": "string" },
    "admitted": { "type": "boolean" },
    "decision": {
      "type": "string",
      "enum": ["admit", "reject", "promote", "merge", "supersede", "decay", "archive", "evict"]
    },
    "slot": { "type": ["string", "null"] },
    "score": { "type": "number" },
    "reason": { "type": "string" }
  },
  "additionalProperties": false
}
